# ConvocAItion Configuration
# Copy to .env and fill in values

# Secret key for JWT signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# LLM Configuration (OpenAI-compatible endpoint)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=your-model-name

# Site Configuration
SITE_TITLE=Kingshot Alliance
SITE_DESCRIPTION=Your community's site. Owned by everyone.
SITE_URL=http://localhost:8080

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=

# VAPID keys for push notifications (generate with: python -m convocation.notifications.vapid_gen)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com

# Admin bootstrap (used on first run only)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately
